{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(/tmp/*)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(which *)",
      "Bash(chmod *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(nvim --headless *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(tree *)",
      "Bash(lsof *)",
      "Bash(ss *)",
      "Bash(systemctl status *)",
      "Bash(apt list *)",
      "Bash(curl localhost*)",
      "Bash(curl http://localhost*)",
      "Read(~/.claude/CLAUDE.md)",
      "Read(/tmp/*)",
      "Edit(/tmp/*)",
      "Write(/tmp/*)"
    ]
  },
  "attribution": {
    "commit": ""
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "phpstorm-plugin@phpstorm-marketplace": true,
    "caveman@caveman": true,
    "frontend-design@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "phpstorm-marketplace": {
      "source": {
        "source": "github",
        "repo": "jetbrains/phpstorm-claude-marketplace"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "high",
  "voiceEnabled": true
}
